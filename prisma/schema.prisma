generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String              @id @default(cuid())
  email            String              @unique
  passwordHash     String
  name             String?
  plan             String              @default("hobby")
  createdAt        DateTime            @default(now())
  apiaries         Apiary[]
  tasks            Task[]
  breedingLines    BreedingLine[]
  products         Product[]
  customers        Customer[]
  sales            Sale[]
  consignments     Consignment[]
  commissionStores CommissionStore[]
  expenses         Expense[]
  stockCorrections StockCorrection[]
  accounts         Account[]
  sessions         Session[]
}

model Apiary {
  id              String    @id @default(cuid())
  name            String
  lat             Float?
  lng             Float?
  notes           String?
  status          String    @default("active")
  statusNote      String?
  statusChangedAt DateTime?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  colonies        Colony[]
  tasks           Task[]
  createdAt       DateTime  @default(now())
}

model Colony {
  id              String          @id @default(cuid())
  name            String
  queenYear       Int?
  queenColor      String?
  status          String          @default("active")
  statusNote      String?
  statusChangedAt DateTime?
  apiaryId        String
  apiary          Apiary          @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  inspections     Inspection[]
  treatments      Treatment[]
  nfcTags         NfcTag[]
  tasks           Task[]
  breedingBatches BreedingBatch[]
  createdAt       DateTime        @default(now())
  foundedAt       DateTime?
  notes           String?
}

model Inspection {
  id             String           @id @default(cuid())
  date           DateTime         @default(now())
  notes          String?
  createdOffline Boolean          @default(false)
  colonyId       String
  colony         Colony           @relation(fields: [colonyId], references: [id], onDelete: Cascade)
  items          InspectionItem[]
  createdAt      DateTime         @default(now())
}

model InspectionItem {
  id           String     @id @default(cuid())
  key          String
  value        String
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model Treatment {
  id        String   @id @default(cuid())
  type      String
  amount    Float?
  unit      String?
  date      DateTime @default(now())
  notes     String?
  colonyId  String
  colony    Colony   @relation(fields: [colonyId], references: [id], onDelete: Cascade)
}

model NfcTag {
  id        String      @id @default(cuid())
  uid       String      @unique
  label     String?
  colonyId  String
  colony    Colony      @relation(fields: [colonyId], references: [id], onDelete: Cascade)
  actions   NfcAction[]
  createdAt DateTime    @default(now())
}

model NfcAction {
  id            String  @id @default(cuid())
  type          String
  defaultValues Json?
  nfcTagId      String
  nfcTag        NfcTag  @relation(fields: [nfcTagId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  priority    String    @default("normal")
  colonyId    String?
  colony      Colony?   @relation(fields: [colonyId], references: [id], onDelete: SetNull)
  apiaryId    String?
  apiary      Apiary?   @relation(fields: [apiaryId], references: [id], onDelete: SetNull)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model BreedingLine {
  id          String          @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches     BreedingBatch[]
  createdAt   DateTime        @default(now())
}

model BreedingBatch {
  id             String          @id @default(cuid())
  graftDate      DateTime
  notes          String?
  status         String          @default("active")
  lineId         String
  line           BreedingLine    @relation(fields: [lineId], references: [id], onDelete: Cascade)
  motherColonyId String?
  motherColony   Colony?         @relation(fields: [motherColonyId], references: [id], onDelete: SetNull)
  events         BreedingEvent[]
  createdAt      DateTime        @default(now())
}

model BreedingEvent {
  id        String        @id @default(cuid())
  type      String
  date      DateTime
  completed Boolean       @default(false)
  notes     String?
  batchId   String
  batch     BreedingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

// Kassenbuch
model Product {
  id               String            @id @default(cuid())
  name             String
  unit             String            @default("Stück")
  price            Float
  description      String?
  fillAmount       Float?
  fillUnit         String?
  stockQuantity    Int               @default(0)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleItems        SaleItem[]
  consignmentItems ConsignmentItem[]
  stockCorrections StockCorrection[]
  createdAt        DateTime          @default(now())
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  address      String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales        Sale[]
  consignments Consignment[]
  createdAt    DateTime      @default(now())
}

model CommissionStore {
  id           String        @id @default(cuid())
  name         String
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  consignments Consignment[]
  createdAt    DateTime      @default(now())
}

model Sale {
  id           String     @id @default(cuid())
  date         DateTime   @default(now())
  customerName String?
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        SaleItem[]
  total        Float      @default(0)
  notes        String?
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Float
  price     Float
  total     Float
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Consignment {
  id               String            @id @default(cuid())
  date             DateTime          @default(now())
  locationName     String?
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  commissionStoreId String?
  commissionStore  CommissionStore?  @relation(fields: [commissionStoreId], references: [id], onDelete: SetNull)
  items            ConsignmentItem[]
  status           String            @default("active")
  notes            String?
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
}

model ConsignmentItem {
  id               String      @id @default(cuid())
  quantity         Float
  price            Float
  soldQuantity     Float       @default(0)
  returnedQuantity Float       @default(0)
  consignmentId    String
  consignment      Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  productId        String
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  amount      Float
  category    String   @default("Sonstiges")
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model StockCorrection {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  reason      String
  batchNumber String?
  expiryDate  DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
